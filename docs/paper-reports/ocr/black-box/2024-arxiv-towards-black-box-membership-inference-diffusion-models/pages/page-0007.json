      {
        "block_label": "text",
        "block_content": "image.The results, presented in Table 2, demonstrate that our method outperforms baseline algorithms and does not require access to the Vision Transformer.",
        "block_bbox": [
          85,
          69,
          595,
          156
        ],
        "block_id": 1,
