            85.0,
            156.0
          ]
        ]
      },
      {
        "block_label": "text",
        "block_content": "We also plot ROC curves for the DDIM train on CIFAR-10 and the Diffusion Transformer train on ImageNet in Appendix B. The curves further demonstrate the effectiveness of our method.",
        "block_bbox": [
          85,
          161,
          597,
