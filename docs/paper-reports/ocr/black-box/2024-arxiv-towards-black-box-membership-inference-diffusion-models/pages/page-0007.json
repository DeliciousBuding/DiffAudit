          ],
          [
            284.0,
            846.0
          ],
          [
            284.0,
            872.0
          ],
          [
            86.0,
            872.0
          ]
        ]
      },
      {
        "block_label": "text",
        "block_content": "In this section, we alter some experimental parameters to test the robustness of our algorithm. We primarily focus on the ablation study of DDIM and Diffusion Transformer, while the ablation study related to Stable Diffusion is provided in Appendix B.",
        "block_bbox": [
          84,
          877,
          594,
          1007
        ],
        "block_id": 7,
        "block_order": 7,
        "group_id": 7,
        "global_block_id": 115,
        "global_group_id": 115,
        "block_polygon_points": [
          [
            84.0,
            877.0
          ],
          [
            594.0,
            877.0
          ],
          [
            594.0,
            1007.0
          ],
          [
            84.0,
            1007.0
          ]
        ]
      },
      {
        "block_label": "text",
        "block_content": "The Impact of Average Numbers We test the effect of using different averaging numbers n on the results, as shown in Figure 3. It can be observed that averaging the images from multiple independent samples to generate the output  $ \\hat{x} $ further improves accuracy. This observation validates the algorithm design intuition discussed in Section 4.2. Additional figures showing the ASR results are presented in Appendix B.",
        "block_bbox": [
          84,
          1020,
          596,
          1229
        ],
        "block_id": 8,
        "block_order": 8,
        "group_id": 8,
        "global_block_id": 116,
        "global_group_id": 116,
        "block_polygon_points": [
          [
            84.0,
