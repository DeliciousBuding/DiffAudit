          ]
        ]
      },
      {
        "block_label": "paragraph_title",
        "block_content": "5.5. Ablation Studies",
        "block_bbox": [
          86,
          846,
          284,
          872
        ],
        "block_id": 6,
        "block_order": 6,
        "group_id": 6,
        "global_block_id": 114,
        "global_group_id": 114,
        "block_polygon_points": [
          [
            86.0,
