      {
        "block_label": "display_formula",
        "block_content": " $$ L(\\theta)=\\mathbb{E}_{\\epsilon\\sim\\mathcal{N}(0,\\mathbf{I})}\\left[\\left\\|\\epsilon-\\epsilon_{\\theta}\\left(\\sqrt{\\bar{\\alpha}_{t}}x_{0}+\\sqrt{1-\\bar{\\alpha}_{t}}\\epsilon,t\\right)\\right\\|^{2}\\right]. $$ ",
        "block_bbox": [
