      "imgs/img_in_image_box_206_207_982_662.jpg": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/pp-ocr-vl-15//06699ef5-5fb9-4340-9338-90d43b8130c9/markdown_1/imgs/img_in_image_box_206_207_982_662.jpg?authorization=bce-auth-v1%2FALTAKzReLNvew3ySINYJ0fuAMN%2F2026-04-05T13%3A44%3A12Z%2F-1%2F%2F54534ae421fdff086faa98d6c518dff37c287cd75a7d03b212b661b041065884",
