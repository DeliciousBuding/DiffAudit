      {
        "block_label": "table",
        "block_content": "<table><tr><td>Method</td><td>ASR</td><td>AUC</td><td>TPR@1%FPR</td><td>TPR@0.1%FPR</td><td>Time (seconds)</td></tr><tr><td>Effective</td><td>0.947</td><td>0.992</td><td>0.663</td><td>0.311</td><td>21587</td></tr><tr><td>Poisson</td><td>0.801</td><td>0.882</td><td>0.270</td><td>0.053</td><td>2422</td></tr><tr><td>Equidistant</td><td>0.932</td><td>0.981</td><td>0.641</td><td>0.304</td><td>2398</td></tr></table>",
