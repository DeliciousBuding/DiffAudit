      {
        "block_label": "paragraph_title",
        "block_content": "9 Related Work",
        "block_bbox": [
          83,
          844,
          270,
          869
        ],
        "block_id": 7,
        "block_order": 4,
        "group_id": 7,
        "global_block_id": 240,
        "global_group_id": 240,
        "block_polygon_points": [
          [
