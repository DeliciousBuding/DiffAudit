      {
        "block_label": "text",
        "block_content": "Yang Zhang\nCISPA Helmholtz Center for\nInformation Security\nzhang@cispa.de",
        "block_bbox": [
          667,
          289,
          925,
          402
        ],
        "block_id": 10,
        "block_order": 11,
        "group_id": 10,
        "global_block_id": 10,
        "global_group_id": 10,
        "block_polygon_points": [
          [
            667.0,
