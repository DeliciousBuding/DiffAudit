          ]
        ]
      },
      {
        "block_label": "text",
        "block_content": "",
        "block_bbox": [
          635,
          420,
          1175,
          734
        ],
        "block_id": 12,
        "block_order": 13,
        "group_id": 11,
        "global_block_id": 12,
        "global_group_id": 12,
        "block_polygon_points": [
          [
            635.0,
            420.0
          ],
          [
            1175.0,
            420.0
