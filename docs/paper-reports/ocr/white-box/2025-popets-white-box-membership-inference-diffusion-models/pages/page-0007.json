            776.0
          ]
        ]
      },
      {
        "block_label": "text",
        "block_content": "In our experiments, we ensure an equal number of member and non-member image samples. Given the balanced nature of our dataset and the stability of ASR in such contexts, we employ ASR as our primary evaluation metric.",
        "block_bbox": [
          629,
          775,
          1154,
          872
        ],
        "block_id": 16,
        "block_order": 9,
        "group_id": 16,
