        "block_content": "<table><tr><td rowspan=\"2\">Attack method</td><td colspan=\"2\">ASR $ \\uparrow $</td><td colspan=\"3\">AUC $ \\uparrow $</td><td colspan=\"3\">TPR@1%FPR $ \\uparrow $</td><td colspan=\"3\">TPR@0.1%FPR $ \\uparrow $</td></tr><tr><td>CIFAR-10</td><td>ImagetNet</td><td>MS COCO</td><td>CIFAR-10</td><td>ImagetNet</td><td>MS COCO</td><td>CIFAR-10</td><td>ImagetNet</td><td>MS COCO</td><td>CIFAR-10</td><td>ImagetNet</td></tr><tr><td>LSA</td><td>0.822</td><td>0.702</td><td>0.684</td><td>0.896</td><td>0.766</td><td>0.746</td><td>0.146</td><td>0.034</td><td>0.073</td><td>0.021</td><td>0.004</td></tr><tr><td>GSA $ _{1} $</td><td>0.993</td><td>0.992</td><td>0.977</td><td>0.999</td><td>0.999</td><td>0.997</td><td>0.997</td><td>0.995</td><td>0.954</td><td>0.829</td><td>0.937</td></tr><tr><td>GSA $ _{2} $</td><td>0.988</td><td>0.983</td><td>0.994</td><td>0.999</td><td>0.999</td><td>0.999</td><td>0.979</td><td>0.964</td><td>0.998</td><td>0.586</td><td>0.743</td></tr></table>",
