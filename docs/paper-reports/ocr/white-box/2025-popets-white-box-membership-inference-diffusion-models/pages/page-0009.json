      },
      {
        "block_label": "paragraph_title",
        "block_content": "5.2 Attacking Unconditional Diffusion Model",
        "block_bbox": [
          86,
          1210,
          577,
          1241
        ],
        "block_id": 11,
        "block_order": 4,
        "group_id": 11,
        "global_block_id": 174,
        "global_group_id": 174,
        "block_polygon_points": [
          [
            86.0,
