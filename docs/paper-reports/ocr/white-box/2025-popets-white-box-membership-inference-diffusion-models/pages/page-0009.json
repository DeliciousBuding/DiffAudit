            1174.0,
            1133.0
          ],
          [
            636.0,
            1133.0
          ]
        ]
      },
      {
        "block_label": "text",
        "block_content": "Then, our experiments explore the influence of the degree of overfitting in both shadow and target models on attack accuracy. Moreover, we examine the impact of discrepancies in data-fitting levels between the target and shadow models on the performance of the attack.",
        "block_bbox": [
          636,
          1130,
          1171,
          1248
        ],
        "block_id": 17,
        "block_order": 10,
        "group_id": 17,
        "global_block_id": 180,
