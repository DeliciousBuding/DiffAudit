          ]
        ]
      },
      {
        "block_label": "text",
        "block_content": "",
        "block_bbox": [
          638,
          546,
          1167,
          621
        ],
        "block_id": 14,
        "block_order": 7,
        "group_id": 13,
        "global_block_id": 177,
        "global_group_id": 177,
        "block_polygon_points": [
          [
            638.0,
